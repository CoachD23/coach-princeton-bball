<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <meta name="description" content="The Princeton Offense Mastery Blueprint — Complete read-based basketball system. Six sets, fourteen counters, 42 drills. Used by 200+ coaches worldwide.">
    <meta name="keywords" content="Princeton Offense, basketball playbook, coaching system, basketball drills, offensive system">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Coach Lee DeForest">
    <link rel="canonical" href="https://coachprincetonbasketball.com/book/">

    <!-- Open Graph Tags -->
    <meta property="og:title" content="The Princeton Offense Mastery Blueprint — Coach Princeton Basketball">
    <meta property="og:description" content="Complete read-based basketball system with six interchangeable sets, fourteen counters, and 42 detailed drills.">
    <meta property="article:author" content="Coach Lee DeForest">
    <meta property="og:type" content="product">
    <meta property="og:url" content="https://coachprincetonbasketball.com/book">
    <meta property="og:image" content="https://coachprincetonbasketball.com/og-image.jpg">

    <!-- Twitter Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="The Princeton Offense Mastery Blueprint">
    <meta name="twitter:description" content="Complete read-based basketball system for coaches at every level.">
    <meta name="twitter:image" content="https://coachprincetonbasketball.com/og-image.jpg">

    <title>The Princeton Offense Mastery Blueprint — Coach Princeton Basketball</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-11158472206"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'AW-11158472206');
    </script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0a0a0a;
            color: #ffffff;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Sticky Navigation */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
            padding: 1.2rem 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        nav.scrolled {
            padding: 0.8rem 0;
            border-bottom: 1px solid rgba(201, 168, 76, 0.2);
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: #c9a84c;
            text-decoration: none;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .nav-logo:hover {
            color: #e8c96d;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
            align-items: center;
        }

        .nav-links a {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.3s ease;
            border-bottom: 2px solid transparent;
            padding-bottom: 0.25rem;
        }

        .nav-links a:hover {
            color: #c9a84c;
            border-bottom: 2px solid #c9a84c;
        }

        .nav-cta {
            background-color: #c9a84c;
            color: #0a0a0a;
            padding: 0.7rem 1.5rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .nav-cta:hover {
            background-color: #e8c96d;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(201, 168, 76, 0.3);
        }


        /* Hamburger Menu */
        .hamburger { display: none; flex-direction: column; cursor: pointer; gap: 5px; z-index: 1001; }
        .hamburger span { display: block; width: 25px; height: 3px; background: #c9a84c; border-radius: 3px; transition: all 0.3s ease; }
        .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 6px); }
        .hamburger.active span:nth-child(2) { opacity: 0; }
        .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -6px); }

        @media (max-width: 768px) {
            .hamburger { display: flex; }
            .nav-links { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10, 10, 10, 0.98); flex-direction: column; justify-content: center; align-items: center; gap: 2rem; z-index: 999; }
            .nav-links.active { display: flex; }
            .nav-links a { font-size: 1.2rem; }

            .nav-container {
                padding: 0 1rem;
            }
        }

        /* Main Content */
        main {
            margin-top: 60px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Hero Section */
        .hero {
            padding: 100px 2rem;
            background: linear-gradient(135deg, #111111 0%, #0a0a0a 50%, #1a1a1a 100%);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(201, 168, 76, 0.05) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(201, 168, 76, 0.03) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-container {
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
            position: relative;
            z-index: 2;
        }

        h1 {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: #ffffff;
        }

        .hero-subtext {
            font-size: 1.15rem;
            line-height: 1.8;
            color: #cccccc;
            margin-bottom: 3rem;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-primary {
            background-color: #c9a84c;
            color: #0a0a0a;
            padding: 1rem 2.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.2);
        }

        .btn-primary:hover {
            background-color: #e8c96d;
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(201, 168, 76, 0.35);
        }

        /* Content Section */
        .content-section {
            padding: 100px 2rem;
            background-color: #0a0a0a;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .section-title {
            font-size: 2.8rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 4rem;
            color: #ffffff;
        }

        .content-text {
            max-width: 900px;
            margin: 0 auto 3rem;
            font-size: 1.05rem;
            line-height: 1.8;
            color: #cccccc;
            text-align: center;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .feature-card {
            padding: 2.5rem;
            background: rgba(17, 17, 17, 0.6);
            border: 1px solid rgba(201, 168, 76, 0.15);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            background: rgba(17, 17, 17, 0.9);
            border-color: rgba(201, 168, 76, 0.3);
            transform: translateY(-5px);
        }

        .feature-card h3 {
            font-size: 1.3rem;
            margin-bottom: 1.5rem;
            color: #c9a84c;
            font-weight: 700;
        }

        .feature-card ul {
            list-style: none;
        }

        .feature-card li {
            padding: 0.6rem 0;
            color: #bbbbbb;
            padding-left: 1.8rem;
            position: relative;
            font-size: 0.95rem;
        }

        .feature-card li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: #c9a84c;
            font-weight: bold;
        }

        /* Playbook Preview Gallery */
        .preview-section {
            padding: 100px 2rem;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .preview-layout {
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .preview-cover {
            position: relative;
        }

        .preview-cover img {
            width: 100%;
            max-width: 380px;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), 0 0 30px rgba(201, 168, 76, 0.1);
            margin: 0 auto;
            display: block;
        }

        .preview-cover .preview-badge {
            position: absolute;
            top: -12px;
            right: 10%;
            background: #c9a84c;
            color: #0a0a0a;
            font-weight: 700;
            font-size: 0.85rem;
            padding: 0.4rem 1rem;
            border-radius: 20px;
            box-shadow: 0 4px 12px rgba(201, 168, 76, 0.3);
        }

        .preview-diagrams {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .preview-diagrams h3 {
            font-size: 1.3rem;
            color: #c9a84c;
            margin-bottom: 0.5rem;
        }

        .preview-diagrams p {
            color: #999;
            font-size: 1rem;
            line-height: 1.7;
            margin-bottom: 0.5rem;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .preview-grid .preview-card {
            position: relative;
            overflow: hidden;
            border-radius: 6px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: #fff;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .preview-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
        }

        .preview-card img {
            width: 100%;
            display: block;
        }

        .preview-card .preview-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.85));
            padding: 1.5rem 0.7rem 0.5rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: #fff;
        }

        .preview-cta {
            text-align: center;
            margin-top: 1.5rem;
        }

        .preview-cta a {
            color: #c9a84c;
            font-weight: 600;
            text-decoration: none;
            font-size: 1rem;
            transition: color 0.3s;
        }

        .preview-cta a:hover {
            color: #e0c060;
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .preview-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .preview-cover img {
                max-width: 280px;
            }
        }

        .pricing-section {
            padding: 100px 2rem;
            background: rgba(17, 17, 17, 0.5);
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .pricing-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .pricing-card {
            background: rgba(26, 26, 26, 0.8);
            border: 1px solid rgba(201, 168, 76, 0.2);
            padding: 3rem 2.5rem;
            border-radius: 12px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .pricing-card.featured {
            background: rgba(201, 168, 76, 0.08);
            border: 2px solid #c9a84c;
            transform: scaleY(1.05);
            box-shadow: 0 20px 40px rgba(201, 168, 76, 0.15);
        }

        .pricing-card.featured::before {
            content: 'MOST POPULAR';
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #c9a84c;
            color: #0a0a0a;
            padding: 0.5rem 1.5rem;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.75rem;
            letter-spacing: 1px;
        }

        .pricing-name {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .pricing-price {
            font-size: 3rem;
            font-weight: 800;
            color: #c9a84c;
            margin-bottom: 0.5rem;
        }

        .pricing-price small {
            font-size: 1.2rem;
            color: #888888;
        }

        .pricing-description {
            color: #aaaaaa;
            margin-bottom: 2rem;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .pricing-features {
            list-style: none;
            margin-bottom: 2rem;
            text-align: left;
        }

        .pricing-features li {
            padding: 0.6rem 0;
            color: #888888;
            font-size: 0.9rem;
            padding-left: 1.8rem;
            position: relative;
        }

        .pricing-features li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: #c9a84c;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .pricing-button {
            width: 100%;
            padding: 1rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .pricing-card:not(.featured) .pricing-button {
            background-color: transparent;
            color: #c9a84c;
            border: 2px solid #c9a84c;
        }

        .pricing-card:not(.featured) .pricing-button:hover {
            background-color: #c9a84c;
            color: #0a0a0a;
        }

        .pricing-card.featured .pricing-button {
            background-color: #c9a84c;
            color: #0a0a0a;
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.2);
        }

        .pricing-card.featured .pricing-button:hover {
            background-color: #e8c96d;
            box-shadow: 0 12px 35px rgba(201, 168, 76, 0.35);
        }

        .testimonials-section {
            padding: 100px 2rem;
            background-color: #0a0a0a;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .testimonials-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }

        .testimonial-card {
            background: rgba(26, 26, 26, 0.8);
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-left: 4px solid #c9a84c;
            padding: 3rem 2.5rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
        }

        .testimonial-card:hover {
            background: rgba(26, 26, 26, 1);
            border-color: rgba(201, 168, 76, 0.4);
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(201, 168, 76, 0.1);
        }

        .testimonial-text {
            font-size: 1.05rem;
            line-height: 1.8;
            margin-bottom: 1.5rem;
            color: #dddddd;
            font-style: italic;
        }

        .testimonial-author {
            font-weight: 600;
            color: #c9a84c;
            font-size: 0.95rem;
        }

        .testimonial-title {
            font-size: 0.85rem;
            color: #888888;
            margin-top: 0.3rem;
        }

        .guarantee-section {
            padding: 100px 2rem;
            background: rgba(17, 17, 17, 0.5);
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .guarantee-container {
            max-width: 900px;
            margin: 0 auto;
            background: linear-gradient(135deg, rgba(201, 168, 76, 0.1) 0%, rgba(201, 168, 76, 0.05) 100%);
            border: 2px solid rgba(201, 168, 76, 0.3);
            padding: 4rem 3rem;
            border-radius: 12px;
            text-align: center;
        }

        .guarantee-container h2 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            color: #c9a84c;
        }

        .guarantee-text {
            font-size: 1.05rem;
            color: #cccccc;
            line-height: 1.8;
            margin-bottom: 2rem;
        }

        .faq-section {
            padding: 100px 2rem;
            background-color: #0a0a0a;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }

        .faq-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .faq-item {
            background: rgba(26, 26, 26, 0.8);
            border: 1px solid rgba(201, 168, 76, 0.2);
            margin-bottom: 1rem;
            border-radius: 8px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .faq-item:hover {
            border-color: rgba(201, 168, 76, 0.4);
        }

        .faq-question {
            padding: 1.5rem;
            background: transparent;
            border: none;
            width: 100%;
            text-align: left;
            font-size: 1.05rem;
            font-weight: 600;
            color: #ffffff;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .faq-question:hover {
            color: #c9a84c;
        }

        .faq-toggle {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #c9a84c;
            font-size: 1.2rem;
            transition: transform 0.3s ease;
            flex-shrink: 0;
            margin-left: 1rem;
        }

        .faq-item.active .faq-toggle {
            transform: rotate(180deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .faq-item.active .faq-answer {
            max-height: 500px;
        }

        .faq-content {
            padding: 1.5rem;
            padding-top: 0;
            color: #aaaaaa;
            line-height: 1.7;
            font-size: 0.95rem;
        }

        .cta-section {
            padding: 100px 2rem;
            background: linear-gradient(135deg, rgba(201, 168, 76, 0.1) 0%, rgba(201, 168, 76, 0.05) 100%);
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
            text-align: center;
        }

        .cta-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .cta-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            color: #ffffff;
        }

        .cta-text {
            font-size: 1.1rem;
            color: #cccccc;
            margin-bottom: 3rem;
            line-height: 1.8;
        }

        /* Footer */
        footer {
            background-color: #000000;
            border-top: 1px solid rgba(201, 168, 76, 0.1);
            padding: 4rem 2rem 2rem;
            color: #888888;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 3rem;
        }

        .footer-section h4 {
            color: #ffffff;
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            letter-spacing: 0.5px;
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section li {
            margin-bottom: 0.8rem;
        }

        .footer-section a {
            color: #888888;
            text-decoration: none;
            transition: color 0.3s ease;
            font-size: 0.9rem;
        }

        .footer-section a:hover {
            color: #c9a84c;
        }

        .footer-bottom {
            border-top: 1px solid rgba(201, 168, 76, 0.1);
            padding-top: 2rem;
            text-align: center;
            font-size: 0.85rem;
            color: #666666;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .scroll-animate {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease;
        }

        .scroll-animate.visible {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 2.2rem;
            }

            .section-title {
                font-size: 1.8rem;
            }

            .hero {
                padding: 60px 1rem;
            }

            .pricing-card.featured {
                transform: scaleY(1);
            }

            .nav-cta { display: inline-block !important; }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav id="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo">Coach Princeton Basketball</a>
            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <ul class="nav-links" id="navLinks">
                <li><a href="/about/">About</a></li>
                <li><a href="/book/">Playbook</a></li>
