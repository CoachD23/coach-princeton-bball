    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": "Coach Princeton Basketball - Mastery Blueprint",
        "description": "Complete read-based basketball offensive system with six interchangeable sets, fourteen counter packages, and 42 breakdown drills",
        "brand": {
            "@type": "Brand",
            "name": "Coach Princeton Basketball"
        },
        "offers": [
            {
                "@type": "Offer",
                "price": "39",
                "priceCurrency": "USD",
                "availability": "https://schema.org/InStock",
                "name": "Playbook"
            },
            {
                "@type": "Offer",
                "price": "49",
                "priceCurrency": "USD",
                "availability": "https://schema.org/InStock",
                "name": "Bundle"
            }
        ],
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
